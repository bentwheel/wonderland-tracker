# Copy to .env (referenced by tracker-api.service) and fill in the real token.
# Generate a strong token, e.g.:  openssl rand -hex 24
ADMIN_UPLOAD_TOKEN=replace-me-with-a-long-random-secret

# Optional overrides (defaults shown):
# PORT=8788   # 8787 is taken on wavebeam (RStudio); the API uses 8788
# PHOTO_TIME_MATCH_HOURS=6   # max hours between a photo's capture time and the
#                            # nearest ping for time-based placement (default 6)
# TRACKER_DB_PATH=/opt/wonderland-tracker/data/locations.db
# PHOTO_DIR=/opt/wonderland-tracker/data/photos
# CORS_ORIGIN=https://cslester.com
